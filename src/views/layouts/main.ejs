<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="topbar">
    <a href="/" class="brand">ScammerVault</a>
    <nav>
      <% if (!currentUser) { %>
        <a href="/login">Login</a>
        <a href="/register">Daftar</a>
      <% } else { %>
        <span>Hai, <%= currentUser.name %></span>
        <form method="post" action="/logout" class="inline"><button>Logout</button></form>
      <% } %>
    </nav>
  </header>
  <main class="container">
    <% if (flash.error && flash.error.length) { %><p class="flash error"><%= flash.error[0] %></p><% } %>
    <% if (flash.success && flash.success.length) { %><p class="flash success"><%= flash.success[0] %></p><% } %>
    <%- body %>
  </main>
</body>
</html>
